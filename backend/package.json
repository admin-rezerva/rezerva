{
  "name": "staymanager-backend",
  "version": "1.0.0",
  "description": "Backend for StayManager",
  "main": "index.js",
  "scripts": {
    "start": "npm run build && node index.js",
    "build:css": "tailwindcss -i ../frontend/public/css/source.css -o ../frontend/public/css/style.css --minify && echo 'Admin CSS build completed.'",
    "build:website-css": "tailwindcss -i ./public/css/website-source.css -o ./public/css/website.css --minify && echo 'Website CSS build completed.'",
    "build": "npm run build:css && npm run build:website-css",
    "firebase:deploy-storage": "firebase deploy --only storage --config firebase/firebase.json"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "cheerio": "^1.2.0",
    "cors": "^2.8.5",
    "csv-parse": "^6.1.0",
    "csv-parser": "^3.0.0",
    "date-fns": "^3.0.0",
    "dotenv": "^17.2.3",
    "ejs": "^3.1.9",
    "express": "^4.19.2",
    "express-rate-limit": "^8.2.1",
    "express-slow-down": "^3.0.1",
    "exceljs": "^4.4.0",
    "fast-xml-parser": "^5.7.3",
    "firebase-admin": "^13.8.0",
    "fuse.js": "^7.1.0",
    "google-auth-library": "^9.4.1",
    "googleapis": "^128.0.0",
    "http-proxy-middleware": "^3.0.5",
    "imapflow": "^1.2.18",
    "mercadopago": "^2.11.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.2.1",
    "node-fetch": "^2.7.0",
    "node-ical": "^0.26.1",
    "pg": "^8.20.0",
    "resend": "^6.9.4",
    "sharp": "^0.34.4",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "firebase-tools": "^14.12.0",
    "tailwindcss": "^3.4.1"
  },
  "overrides": {
    "http-proxy-agent": "^7.0.2"
  }
}
