# Plantilla de variables para el backend (copiar a `.env` en esta carpeta; no commitear secretos).
# Documentación: SHARED_CONTEXT.md apartado 2.1 (desarrollo local).

# --- PostgreSQL (recomendado para desarrollo con reservas, clientes, SSR/IA) ---
# Sin DATABASE_URL el motor queda en Firestore legacy y `pool` es null → muchas rutas no operan.
# DB_MODE=postgres
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

# --- Node ---
# NODE_ENV=development

# --- API pública IA (ChatGPT / Actions) — endurecer respuestas para GPT Store o clientes finales ---
# Por defecto desactivado: las respuestas conservan telemetría útil para QA (payload_version, diagnósticos, etc.).
# Con 1: se eliminan del JSON campos técnicos, errores de correo detallados, candidatos de catalog_id, etc.
# Versión de contrato que devuelve GET /api/public/version (alineada a openapi-gemini.yaml / openapi-chatgpt.yaml info.version).
# PUBLIC_API_CONTRACT_VERSION=1.4.7
#
# PUBLIC_AI_SANITIZE_RESPONSES=1
# (sinónimo) PUBLIC_AI_PUBLIC_MODE=1
#
# Rate limits API pública (opcionales):
# - workflow: resolve/cotizar/intent (por IP+empresa)
# - create reservation: POST /api/public/reservas (por IP+empresa+email huésped)
# BOOKING_WORKFLOW_WINDOW_MS=900000
# BOOKING_WORKFLOW_MAX=20
# CREATE_RESERVATION_WINDOW_MS=900000
# CREATE_RESERVATION_MAX=5
# TRUSTED_IPS=1.2.3.4,5.6.7.8

# --- Email (local) ---
# Opción 1: Resend (recomendado en staging/producción)
# RESEND_API_KEY=re_xxxxx
# EMAIL_FROM=reservas@tu-dominio.com
#
# Opción 2: Gmail SMTP (útil en local con App Password)
# EMAIL_USER=tu_cuenta@gmail.com
# EMAIL_PASS=tu_app_password_de_16_caracteres
# EMAIL_FROM=tu_cuenta@gmail.com
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
#
# Nota: EMAIL_PASS no es tu contraseña normal; debe ser App Password de Google.

# --- Smoke SSR local (`npm run test:ssr` → verify_ssr_integrity.js) ---
# Sin esto, force_host por defecto puede no resolver tenant en tu BD y el script verá el shell del panel.
# SSR_VERIFY_BASE_URL=http://localhost:3001
# SSR_VERIFY_FORCE_HOST=tu-empresa.suitemanagers.com
# SSR_VERIFY_PROPERTY_ID=uuid-firestore-de-una-propiedad-de-esa-empresa

# --- Google Hotels Connectivity Partner (feeds globales /feeds/google — TASKS/tema/SM-venta-ia/venta-ia.md §7) ---
# Host dedicado: api.<PLATFORM_DOMAIN> o feeds.<PLATFORM_DOMAIN> (CNAME a tu servicio). En local: localhost.
# Token largo en query: ?auth=... (compartir solo con Google + operación).
# GOOGLE_PARTNER_FEED_AUTH_TOKEN=genera-un-uuid-largo
# Opcional: GOOGLE_PARTNER_EXTRA_HOSTS=staging-xxx.onrender.com
# Opcional: GOOGLE_PARTNER_ARI_DAYS=180
# GOOGLE_PARTNER_RATE_PLAN_ID=sm_direct_lowest
# Place ID obligatorio en feed global además de lat/lng: GOOGLE_PARTNER_REQUIRE_PLACE_ID=1 (§7.5)
# Si las tarifas en BD son netas y deben publicarse con IVA en <Baserate> (solo partner ARI): GOOGLE_PARTNER_ARI_NET_RATES=1
# Solo desarrollo: ALLOW_PARTNER_FEED_WITHOUT_AUTH=1 (nunca en producción)
# §7.10: con `xmllint` en PATH y esquema oficial local (`hotel_inventory.xsd` o el que use Google):
# GOOGLE_HOTELS_XSD_PATH=/ruta/completa/hotel_inventory.xsd
#
# Feed contenido por tenant (/feed-google-hotels-content.xml) con token en panel:
# Si Google (o otro verificador) llama sin ?token=, puedes permitir por User-Agent (coma-separado, substring case-insensitive).
# Ej.: Googlebot,Google-InspectionTool,AdsBot-Google — solo si aceptas el riesgo de spoofing de UA (TASKS/tema/SM-venta-ia/venta-ia.md §7.4).
# GOOGLE_HOTELS_CONTENT_FEED_VERIFIER_UA_SUBSTR=Googlebot,Google-InspectionTool

# Smoke HTTP contra prod/staging (solo en tu máquina; no commitear token):
# GH_PARTNER_FEED_BASE_URL=https://suite-manager.onrender.com
# GH_PARTNER_FEED_AUTH_TOKEN=mismo-valor-que-GOOGLE_PARTNER_FEED_AUTH_TOKEN-en-el-servidor
# Opcional: GH_PARTNER_FEED_STRICT=1 — exige <Property> en ambos XML (npm run smoke:partner-feeds)
# URL pública usada por el panel (Canales IA) y selftest servidor→feeds (si difiere de feeds.<PLATAFORMA>):
# GOOGLE_PARTNER_FEED_SELFTEST_BASE_URL=https://feeds.suitemanagers.com

# (Resto: Firebase, JWT, MercadoPago, etc. según tu entorno; no duplicar aquí valores sensibles.)
