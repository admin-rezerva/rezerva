<%- /* Catálogo opt-in Google Hotels — paridad UI con home (TASKS/tema/SM-auditoria-calidad/solo-ui.md) */ %>
<!DOCTYPE html>
<html lang="<%= mp.htmlLang %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <%- include('../partials/marketplace-theme-color') %>
    <%- include('../partials/marketplace-favicon') %>
    <%- include('../partials/marketplace-preload-logo') %>
    <%- include('../partials/ssr-preconnect-cdnjs') %>
    <title><%= mp.ghCatalogPageTitle %></title>
    <meta name="description" content="<%= mp.ghCatalogMetaDescription %>">
    <link rel="canonical" href="<%= canonicalUrl %>">
    <link rel="alternate" hreflang="es" href="<%= hreflangEsUrl %>">
    <link rel="alternate" hreflang="en" href="<%= hreflangEnUrl %>">
    <link rel="alternate" hreflang="x-default" href="<%= hreflangEsUrl %>">
    <meta property="og:type" content="website">
    <meta property="og:site_name" content="<%= mp.brandLabel %>">
    <meta property="og:locale" content="<%= mp.ogLocale %>">
    <meta property="og:title" content="<%= mp.ghCatalogPageTitle %>">
    <meta property="og:description" content="<%= mp.ghCatalogMetaDescription %>">
    <meta property="og:url" content="<%= canonicalUrl %>">
    <% if (typeof ogImage === 'string' && ogImage) { %>
    <meta property="og:image" content="<%= ogImage %>">
    <% if (typeof ogImageUsesBrandAsset !== 'undefined' && ogImageUsesBrandAsset) { %>
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta property="og:image:type" content="image/png">
    <meta property="og:image:alt" content="<%= mp.brandLabel %>">
    <% } %>
    <% } %>
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= mp.ghCatalogPageTitle %>">
    <meta name="twitter:description" content="<%= mp.ghCatalogMetaDescription %>">
    <% if (typeof ogImage === 'string' && ogImage) { %>
    <meta name="twitter:image" content="<%= ogImage %>">
    <% } %>

    <% if (!postgresRequired && items.length > 0) { %>
    <script type="application/ld+json">
    <%- JSON.stringify({
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [
            { "@type": "ListItem", "position": 1, "name": mp.jsonLdBreadcrumbHome, "item": marketplaceHomeAbsoluteUrl },
            { "@type": "ListItem", "position": 2, "name": mp.jsonLdBreadcrumbGoogleHotels, "item": canonicalUrl }
        ]
    }) %>
    </script>
    <script type="application/ld+json">
    <%- JSON.stringify({
        "@context": "https://schema.org",
        "@type": "ItemList",
        "name": mp.ghCatalogHeading,
        "description": mp.ghCatalogMetaDescription,
        "numberOfItems": items.length,
        "itemListElement": items.slice(0, 24).map((it, i) => ({
            "@type": "ListItem",
            "position": i + 1,
            "item": {
                "@type": "LodgingBusiness",
                "name": it.title,
                "url": it.deepLink,
                ...(it.fotoUrl ? { "image": it.fotoUrl } : {}),
                ...(it.city ? { "address": { "@type": "PostalAddress", "addressLocality": it.city } } : {})
            }
        }))
    }) %>
    </script>
    <% } %>

    <link rel="stylesheet" href="/public/css/website.css">
    <%- include('../partials/web-fonts') %>
    <%- include('../partials/ssr-fontawesome-deferred') %>
    <%- include('../partials/marketplace-common-styles') %>
</head>
<body class="mp-marketplace min-h-screen antialiased">
<%- include('../partials/marketplace-skip-main') %>

<header class="mp-header">
    <div class="mp-header__row max-w-7xl mx-auto px-4 sm:px-6 lg:px-10 flex flex-wrap items-center gap-3 lg:gap-6">
        <%- include('../partials/marketplace-brand-logo', { mp, mpHomeUrl, logoVariant: 'header' }) %>

        <a href="<%= mpHomeUrl %>" class="mp-header__link hidden sm:inline-flex text-sm font-semibold px-1 py-0.5 rounded-md whitespace-nowrap">
            <%= mp.ghCatalogBackHome %>
        </a>

        <nav class="flex flex-1 flex-wrap items-center justify-end gap-2 sm:gap-3 text-sm font-semibold">
            <a href="<%= mpHomeUrl %>" class="mp-header__link sm:hidden"><%= mp.ghCatalogBackHome %></a>
            <span class="hidden sm:inline mp-header__sep" aria-hidden="true">|</span>
            <a href="<%= hreflangEsUrl %>" class="mp-header__lang px-2 py-1 rounded-full <%= mp.htmlLang === 'es' ? 'mp-header__lang--active' : '' %>"><%= mp.langSwitchEs %></a>
            <span class="mp-header__sep" aria-hidden="true">|</span>
            <a href="<%= hreflangEnUrl %>" class="mp-header__lang px-2 py-1 rounded-full <%= mp.htmlLang === 'en' ? 'mp-header__lang--active' : '' %>"><%= mp.langSwitchEn %></a>
        </nav>
    </div>
</header>

<section class="mp-hero" aria-labelledby="gh-hero-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-8 pb-8 md:pt-10 md:pb-10">
        <h1 id="gh-hero-heading" class="text-2xl sm:text-3xl md:text-4xl font-semibold tracking-tight text-[#222222] max-w-3xl leading-tight">
            <%= mp.ghCatalogHeading %>
        </h1>
        <p class="mt-3 text-base text-[#717171] max-w-2xl leading-relaxed">
            <%= mp.ghCatalogLead %>
        </p>
    </div>
</section>

<main id="main-content" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-10">

    <% if (postgresRequired) { %>
    <p class="mp-alert-soft"><%= mp.ghCatalogUnavailable %></p>
    <% } else if (items.length === 0) { %>
    <div class="text-center py-16 mp-alert-soft max-w-lg mx-auto">
        <i class="fas fa-hotel text-4xl mb-4 block" style="color:#DDDDDD;"></i>
        <p class="text-[#717171] mb-4"><%= mp.ghCatalogEmpty %></p>
        <a href="<%= mpHomeUrl %>" class="inline-flex items-center gap-2 text-sm font-semibold text-[#222222] underline underline-offset-2 hover:opacity-80">
            <i class="fas fa-arrow-left" style="font-size:12px;"></i> <%= mp.ghCatalogBackHome %>
        </a>
    </div>
    <% } else { %>
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
        <% items.forEach((it) => { %>
        <a href="<%= it.deepLink %>" class="prop-card" rel="noopener noreferrer" aria-label="<%= mp.ariaExternalHost %>: <%= it.title %>">
            <div class="prop-photo">
                <% if (it.fotoUrl) { %>
                    <img src="<%= it.fotoUrl %>" alt="" loading="lazy">
                <% } else { %>
                    <div class="prop-photo-placeholder"><i class="fas fa-home"></i></div>
                <% } %>
            </div>
            <div class="prop-body">
                <p class="prop-title"><%= it.title %></p>
                <% if (it.city) { %><p class="prop-sub"><%= it.city %></p><% } %>
                <div class="mp-gh-cta-row">
                    <span class="mp-gh-cta-text"><%= mp.ghCatalogCta %> <i class="fas fa-external-link-alt" style="font-size:11px;" aria-hidden="true"></i></span>
                </div>
            </div>
        </a>
        <% }); %>
    </div>
    <% } %>
</main>

<%- include('../partials/marketplace-footer', { mp, mpHomeUrl, footerMode: 'google-hotels' }) %>

</body>
</html>
