<%- /* backend/views/marketplace/index.ejs — Homepage Marketplace rezerva.cl */ %>
<!DOCTYPE html>
<html lang="<%= mp.htmlLang %>">
<head>
    <!-- marketplace-build <%= typeof mpAssetV !== 'undefined' ? mpAssetV : '' %> — verificar deploy (Ver código fuente) -->
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <%- include('../partials/marketplace-theme-color') %>
    <%- include('../partials/marketplace-favicon') %>
    <%- include('../partials/marketplace-preload-logo') %>
    <%- include('../partials/ssr-preconnect-cdnjs') %>
    <title><%= mp.pageTitle %></title>
    <meta name="description" content="<%= mp.metaDescription %>">
    <link rel="canonical" href="<%= canonicalUrl %>">
    <link rel="alternate" hreflang="es" href="<%= hreflangEsUrl %>">
    <link rel="alternate" hreflang="en" href="<%= hreflangEnUrl %>">
    <link rel="alternate" hreflang="x-default" href="<%= hreflangEsUrl %>">

    <!-- Open Graph / Social -->
    <meta property="og:type" content="website">
    <meta property="og:site_name" content="<%= mp.brandLabel %>">
    <meta property="og:locale" content="<%= mp.ogLocale %>">
    <meta property="og:title" content="<%= mp.ogTitle %>">
    <meta property="og:description" content="<%= mp.ogDescription %>">
    <meta property="og:url" content="<%= canonicalUrl %>">
    <% if (propiedades.length > 0 && propiedades[0].fotoUrl) { %>
    <meta property="og:image" content="<%= propiedades[0].fotoUrl %>">
    <% } else if (typeof marketplaceBrandImageUrl === 'string' && marketplaceBrandImageUrl) { %>
    <meta property="og:image" content="<%= marketplaceBrandImageUrl %>">
    <% if (typeof ogImageUsesBrandAsset !== 'undefined' && ogImageUsesBrandAsset) { %>
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta property="og:image:type" content="image/png">
    <meta property="og:image:alt" content="<%= mp.brandLabel %>">
    <% } %>
    <% } %>
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= mp.pageTitle %>">
    <meta name="twitter:description" content="<%= mp.twitterDescription %>">
    <% if (propiedades.length > 0 && propiedades[0].fotoUrl) { %>
    <meta name="twitter:image" content="<%= propiedades[0].fotoUrl %>">
    <% } else if (typeof marketplaceBrandImageUrl === 'string' && marketplaceBrandImageUrl) { %>
    <meta name="twitter:image" content="<%= marketplaceBrandImageUrl %>">
    <% } %>

    <!-- Schema.org JSON-LD -->
    <script type="application/ld+json">
    <%- JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      name: mp.brandLabel,
      url: `https://${platformDomain}`,
      description: mp.jsonLdSiteDescription,
      publisher: {
        '@type': 'Organization',
        name: mp.brandLabel,
        url: `https://${platformDomain}`,
        logo: {
          '@type': 'ImageObject',
          url: `https://${platformDomain}/public/branding/logo-bg-white.png`,
          width: 400,
          height: 218,
        },
      },
      potentialAction: {
        '@type': 'SearchAction',
        target: {
          '@type': 'EntryPoint',
          urlTemplate: `https://${platformDomain}/?q={search_term_string}`,
        },
        'query-input': 'required name=search_term_string',
      },
    }) %>
    </script>
    <% if (propiedades.length > 0) { %>
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "ItemList",
      "name": <%- JSON.stringify(mp.jsonLdItemListName) %>,
      "description": <%- JSON.stringify(mp.jsonLdItemListDescription) %>,
      "numberOfItems": <%= propiedades.length %>,
      "itemListElement": [
        <%- propiedades.slice(0, 10).map((p, i) => {
          const tier = precioDesdeToSchemaPriceRange(p.precioDesde);
          return JSON.stringify({
            "@type": "ListItem",
            "position": i + 1,
            "item": {
              "@type": "LodgingBusiness",
              "name": p.titulo,
              "url": p.url,
              "image": p.fotoUrl || undefined,
              "maximumAttendeeCapacity": p.capacidad,
              ...(p.rating ? { "aggregateRating": {
                "@type": "AggregateRating",
                "ratingValue": p.rating,
                "reviewCount": p.numResenas,
                "bestRating": 5
              }} : {}),
              ...(tier ? { "priceRange": tier } : {})
            }
          });
        }).join(',\n        ') %>
      ]
    }
    </script>
    <% } %>

    <link rel="stylesheet" href="/public/css/website.css">
    <%- include('../partials/web-fonts') %>
    <%- include('../partials/ssr-fontawesome-deferred') %>
    <%- include('../partials/marketplace-common-styles') %>
</head>
<body class="mp-marketplace min-h-screen antialiased">
<%- include('../partials/marketplace-skip-main') %>

<!-- ═══ HEADER ═══ -->
<header class="mp-header">
    <div class="mp-header__bar mp-container">
        <div class="mp-header__logo">
            <%- include('../partials/marketplace-brand-logo', { mp, mpHomeUrl, logoVariant: 'header' }) %>
        </div>

        <!-- Search (GET) — desktop: barra completa; móvil: CTA compacta que expande filtros -->
        <% 
        const _mpQ = (typeof busqueda === 'string' ? busqueda : '').trim();
        const mpExpandSearchMobile = !!(hayBusqueda || _mpQ || fechaIn || fechaOut || (personas > 0));
        const _mpSubParts = [];
        if (_mpQ) _mpSubParts.push(_mpQ.length > 32 ? _mpQ.slice(0, 32) + '…' : _mpQ);
        if (fechaIn && fechaOut) _mpSubParts.push(fechaIn + ' — ' + fechaOut);
        else if (fechaIn) _mpSubParts.push(fechaIn);
        if (personas > 0) _mpSubParts.push(String(personas) + ' ' + (personas !== 1 ? mp.people : mp.person));
        const _mpMobileSubActive = _mpSubParts.join(' · ');
        %>
        <form id="mp-search-form" method="GET" action="/" class="mp-header__search min-w-0 w-full"
              data-search-sub-default="<%= mp.htmlLang === 'en' ? 'Where, dates, guests' : 'Destino, fechas y huéspedes' %>"
              data-people-word="<%= mp.people %>"
              data-person-word="<%= mp.person %>">
            <button type="button"
                    id="mp-search-mobile-toggle"
                    class="search-mobile-collapsed <%= mpExpandSearchMobile ? 'search-mobile-collapsed--hidden' : '' %>"
                    aria-expanded="<%= mpExpandSearchMobile ? 'true' : 'false' %>"
                    aria-controls="mp-search-mobile-panel">
                <span class="search-mobile-collapsed__icon" aria-hidden="true"><i class="fas fa-search"></i></span>
                <span class="search-mobile-collapsed__text">
                    <span class="search-mobile-collapsed__title"><%= mp.htmlLang === 'en' ? 'Start your search' : 'Comienza a explorar' %></span>
                    <span id="mp-search-mobile-sub" class="search-mobile-collapsed__sub"><%= _mpMobileSubActive || (mp.htmlLang === 'en' ? 'Where, dates, guests' : 'Destino, fechas y huéspedes') %></span>
                </span>
                <span class="search-mobile-collapsed__chev" aria-hidden="true"><i class="fas fa-chevron-down"></i></span>
            </button>

            <div id="mp-search-mobile-panel" class="search-mobile-panel <%= mpExpandSearchMobile ? 'is-open' : '' %>">
                <div class="search-mobile-panel-header">
                    <span class="search-mobile-panel-title"><%= mp.htmlLang === 'en' ? 'Search' : 'Buscar' %></span>
                    <button type="button" id="mp-search-mobile-close" class="search-mobile-panel-close" aria-label="<%= mp.htmlLang === 'en' ? 'Close search' : 'Cerrar búsqueda' %>">
                        <i class="fas fa-chevron-up"></i>
                    </button>
                </div>
                <div class="search-pill">
                <% if (mp.htmlLang === 'en') { %>
                <input type="hidden" name="lang" value="en">
                <% } %>
                <div class="search-segment search-segment-destino">
                    <label for="s-destino"><%= mp.labelDestino %></label>
                    <input id="s-destino" name="q" type="text"
                           placeholder="<%= mp.placeholderDestino %>"
                           value="<%= busqueda %>">
                </div>
                <div class="search-segment search-segment-llegada">
                    <label for="s-fecha-in"><%= mp.labelLlegada %></label>
                    <input id="s-fecha-in" name="fecha_in" type="date"
                           value="<%= fechaIn %>" style="color-scheme:light;">
                </div>
                <div class="search-segment search-segment-salida">
                    <label for="s-fecha-out"><%= mp.labelSalida %></label>
                    <input id="s-fecha-out" name="fecha_out" type="date"
                           value="<%= fechaOut %>" style="color-scheme:light;">
                </div>
                <div class="search-segment search-segment-huespedes">
                    <label for="s-personas"><%= mp.labelHuespedes %></label>
                    <input id="s-personas" name="personas" type="number"
                           placeholder="<%= mp.placeholderHuespedes %>" min="1" max="20"
                           value="<%= personas > 0 ? personas : '' %>">
                </div>
                <button type="submit" class="search-btn" aria-label="<%= mp.ariaBuscar %>">
                    <i class="fas fa-search"></i>
                </button>
                </div>
            </div>
        </form>

        <div class="mp-header__tools flex items-center justify-end gap-2 sm:gap-3 shrink-0">
            <div class="flex items-center gap-1.5 sm:gap-2 min-w-0">
                <label for="mp-sort" class="mp-header__sort-label text-xs sm:text-sm font-medium whitespace-nowrap hidden sm:inline" style="color:#717171;"><%= mp.labelSort %></label>
                <select id="mp-sort" name="sort" form="mp-search-form"
                        class="mp-header__sort-select text-xs sm:text-sm rounded-full pl-2.5 pr-8 py-2 max-w-[min(100%,11rem)] sm:max-w-none border border-[#DDDDDD] bg-white text-[#222222] focus:outline-none focus:ring-2 focus:ring-[#222222] focus:ring-offset-1"
                        onchange="var f=document.getElementById('mp-search-form'); if(f) f.submit();">
                    <option value="" <%= !sort ? 'selected' : '' %>><%= mp.sortRecommended %></option>
                    <option value="rating" <%= sort === 'rating' ? 'selected' : '' %>><%= mp.sortRating %></option>
                    <option value="valor" <%= sort === 'valor' ? 'selected' : '' %>><%= mp.sortPriceLow %></option>
                    <option value="valor_desc" <%= sort === 'valor_desc' ? 'selected' : '' %>><%= mp.sortPriceHigh %></option>
                </select>
            </div>
            <details class="mp-lang-menu">
                <summary class="mp-lang-menu__btn" aria-label="<%= mp.langSwitchTitle %>">
                    <i class="fas fa-globe" aria-hidden="true"></i>
                </summary>
                <div class="mp-lang-menu__panel" role="menu">
                    <a href="<%= mpLinkEs %>" class="mp-lang-menu__opt <%= mp.htmlLang === 'es' ? 'mp-lang-menu__opt--active' : '' %>" role="menuitem"><%= mp.langSwitchEs %></a>
                    <a href="<%= mpLinkEn %>" class="mp-lang-menu__opt <%= mp.htmlLang === 'en' ? 'mp-lang-menu__opt--active' : '' %>" role="menuitem"><%= mp.langSwitchEn %></a>
                </div>
            </details>
        </div>
    </div>
</header>

<% if (!hayBusqueda) { %>
<section class="mp-hero" aria-labelledby="mp-hero-heading">
    <div class="mp-container pt-8 pb-10 md:pt-12 md:pb-14 text-center">
        <h1 id="mp-hero-heading" class="text-3xl sm:text-4xl md:text-5xl font-semibold tracking-tight text-[#222222] max-w-3xl mx-auto leading-tight">
            <%= mp.heroTitle %>
        </h1>
        <p class="mt-4 text-base sm:text-lg text-[#717171] max-w-2xl mx-auto leading-relaxed">
            <%= mp.heroSubtitle %>
        </p>
    </div>
</section>
<% } %>

<!-- ═══ MAIN ═══ -->
<main id="main-content" class="mp-container py-8 md:py-10">

    <%
    const _priceLocale = mp.htmlLang === 'en' ? 'en-US' : 'es-CL';
    const formatPrecio = (n) => {
        if (!n) return null;
        return '$' + Number(n).toLocaleString(_priceLocale);
    };
    %>

    <!-- Destacados (solo si no hay búsqueda activa) -->
    <% if (!hayBusqueda && destacados.length > 0) { %>
    <section class="mb-14" aria-labelledby="mp-destacados-heading">
        <h2 id="mp-destacados-heading" class="section-title">
            <i class="fas fa-star text-warning-500 mr-2" style="font-size:1.1rem;"></i>
            <%= mp.sectionFavoritos %>
        </h2>
        <div class="mp-card-grid">
            <% destacados.forEach(p => { %>
            <a href="/ir?s=<%= p.subdominio %>&id=<%= p.id %>" class="prop-card">
                <div class="prop-photo">
                    <% if (p.fotoUrl) { %>
                        <img src="<%= p.fotoUrl %>" alt="<%= p.titulo %>" loading="lazy">
                    <% } else { %>
                        <div class="prop-photo-placeholder"><i class="fas fa-home"></i></div>
                    <% } %>
                    <% if (p.tienePromoTarifa && p.promoTarifaPctMax > 0) { %>
                    <span class="mp-badge-promo"><i class="fas fa-tag mr-1"></i>-<%= p.promoTarifaPctMax %>%</span>
                    <% } %>
                    <span class="badge-fav"><i class="fas fa-medal mr-1 text-warning-500"></i><%= mp.badgeFavorito %></span>
                </div>
                <div class="prop-body">
                    <p class="prop-title"><%= p.titulo %></p>
                    <p class="prop-sub"><%= p.empresaNombre %> · <%= p.capacidad %> <%= p.capacidad !== 1 ? mp.people : mp.person %></p>
                    <% if (p.rating) { %>
                    <div class="prop-rating">
                        <i class="fas fa-star text-warning-500" style="font-size:11px;"></i>
                        <%= p.rating %>
                        <% if (p.numResenas > 0) { %><span>(<%= p.numResenas %> <%= mp.reviews %>)</span><% } %>
                    </div>
                    <% } %>
                    <% if (p.precioDesde) { %>
                    <p class="prop-price"><strong><%= formatPrecio(p.precioDesde) %></strong> <em><%= mp.pricePerNight %></em></p>
                    <% } %>
                </div>
            </a>
            <% }); %>
        </div>
    </section>
    <% } %>

    <!-- Resultados / Todos los alojamientos -->
    <section aria-labelledby="mp-lista-heading">
        <% if (hayBusqueda) { %>
        <h1 id="mp-lista-heading" class="section-title">
                <% if (busqueda) { %>
                    <%= mp.sectionResultadosConQuery %> "<strong><%= busqueda %></strong>"
                <% } else { %>
                    <%= mp.sectionAlojamientosPara %> <%= personas %> <%= personas !== 1 ? mp.people : mp.person %>
                <% } %>
                <span class="text-base font-normal text-[#717171] ml-2">· <%= totalResultados %> <%= mp.lodgings %></span>
                <a href="<%= mpHomeUrl %>" class="text-sm font-normal text-[#222222] underline underline-offset-2 hover:opacity-80 ml-4">
                    <i class="fas fa-times-circle mr-1"></i><%= mp.clearFilters %>
                </a>
        </h1>
        <% } else { %>
        <h2 id="mp-lista-heading" class="section-title">
                <%= mp.sectionTodos %>
                <span class="text-base font-normal text-[#717171] ml-2">· <%= totalResultados %></span>
        </h2>
        <% } %>

        <% if (propiedades.length === 0) { %>
        <div class="text-center py-20">
            <i class="fas fa-search text-4xl mb-4" style="color:#DDDDDD;"></i>
            <p class="text-lg text-[#717171]"><%= mp.noResults %></p>
            <a href="<%= mpHomeUrl %>" class="inline-block mt-4 font-semibold text-[#222222] underline underline-offset-2 hover:opacity-80"><%= mp.verTodos %></a>
        </div>
        <% } else { %>
        <div class="mp-card-grid">
            <% propiedades.forEach(p => { %>
            <a href="/ir?s=<%= p.subdominio %>&id=<%= p.id %>" class="prop-card">
                <div class="prop-photo">
                    <% if (p.fotoUrl) { %>
                        <img src="<%= p.fotoUrl %>" alt="<%= p.titulo %>" loading="lazy">
                    <% } else { %>
                        <div class="prop-photo-placeholder"><i class="fas fa-home"></i></div>
                    <% } %>
                    <% if (p.tienePromoTarifa && p.promoTarifaPctMax > 0) { %>
                    <span class="mp-badge-promo"><i class="fas fa-tag mr-1"></i>-<%= p.promoTarifaPctMax %>%</span>
                    <% } %>
                </div>
                <div class="prop-body">
                    <p class="prop-title"><%= p.titulo %></p>
                    <p class="prop-sub"><%= p.empresaNombre %> · <%= p.capacidad %> <%= p.capacidad !== 1 ? mp.people : mp.person %></p>
                    <% if (p.rating) { %>
                    <div class="prop-rating">
                        <i class="fas fa-star text-warning-500" style="font-size:11px;"></i>
                        <%= p.rating %>
                        <% if (p.numResenas > 0) { %><span>(<%= p.numResenas %> <%= mp.reviews %>)</span><% } %>
                    </div>
                    <% } %>
                    <% if (p.precioDesde) { %>
                    <p class="prop-price"><strong><%= formatPrecio(p.precioDesde) %></strong> <em><%= mp.pricePerNight %></em></p>
                    <% } %>
                </div>
            </a>
            <% }); %>
        </div>
        <% } %>
    </section>
</main>

<%- include('../partials/marketplace-footer', { mp, mpHomeUrl, footerMode: 'home' }) %>

<script>
(function () {
    var form = document.getElementById('mp-search-form');
    var toggle = document.getElementById('mp-search-mobile-toggle');
    var panel = document.getElementById('mp-search-mobile-panel');
    var closeBtn = document.getElementById('mp-search-mobile-close');
    if (!form || !toggle || !panel) return;

    function defaultSub() {
        return form.getAttribute('data-search-sub-default') || '';
    }

    function updateMobileSearchSub() {
        var subEl = document.getElementById('mp-search-mobile-sub');
        if (!subEl) return;
        var qEl = document.getElementById('s-destino');
        var fiEl = document.getElementById('s-fecha-in');
        var foEl = document.getElementById('s-fecha-out');
        var pEl = document.getElementById('s-personas');
        var q = (qEl && qEl.value) ? String(qEl.value).trim() : '';
        var fi = (fiEl && fiEl.value) ? String(fiEl.value) : '';
        var fo = (foEl && foEl.value) ? String(foEl.value) : '';
        var pe = (pEl && pEl.value) ? String(pEl.value).trim() : '';
        var parts = [];
        if (q) parts.push(q.length > 32 ? q.slice(0, 32) + '\u2026' : q);
        if (fi && fo) parts.push(fi + ' \u2014 ' + fo);
        else if (fi) parts.push(fi);
        if (pe && Number(pe) > 0) {
            var n = Number(pe);
            var pw = form.getAttribute('data-people-word') || '';
            var ps = form.getAttribute('data-person-word') || '';
            parts.push(n + ' ' + (n !== 1 ? pw : ps));
        }
        subEl.textContent = parts.length ? parts.join(' \u00B7 ') : defaultSub();
    }

    function isWide() {
        return window.matchMedia('(min-width: 768px)').matches;
    }

    function openPanel() {
        if (isWide()) return;
        panel.classList.add('is-open');
        toggle.classList.add('search-mobile-collapsed--hidden');
        toggle.setAttribute('aria-expanded', 'true');
        var dest = document.getElementById('s-destino');
        if (dest) window.setTimeout(function () { dest.focus(); }, 200);
    }

    function closePanel() {
        if (isWide()) return;
        updateMobileSearchSub();
        panel.classList.remove('is-open');
        toggle.classList.remove('search-mobile-collapsed--hidden');
        toggle.setAttribute('aria-expanded', 'false');
    }

    toggle.addEventListener('click', function () {
        if (panel.classList.contains('is-open')) closePanel();
        else openPanel();
    });
    if (closeBtn) closeBtn.addEventListener('click', closePanel);

    ['s-destino', 's-fecha-in', 's-fecha-out', 's-personas'].forEach(function (id) {
        var el = document.getElementById(id);
        if (!el) return;
        el.addEventListener('change', updateMobileSearchSub);
        if (id === 's-destino' || id === 's-personas') el.addEventListener('input', updateMobileSearchSub);
    });
})();
</script>

</body>
</html>
