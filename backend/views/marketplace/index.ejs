<%- /* backend/views/marketplace/index.ejs — Homepage Marketplace rezerva.cl */ %>
<!DOCTYPE html>
<html lang="<%= mp.htmlLang %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <%- include('../partials/ssr-preconnect-cdnjs') %>
    <title><%= mp.pageTitle %></title>
    <meta name="description" content="<%= mp.metaDescription %>">
    <link rel="canonical" href="<%= canonicalUrl %>">
    <link rel="alternate" hreflang="es" href="<%= hreflangEsUrl %>">
    <link rel="alternate" hreflang="en" href="<%= hreflangEnUrl %>">
    <link rel="alternate" hreflang="x-default" href="<%= hreflangEsUrl %>">

    <!-- Open Graph / Social -->
    <meta property="og:type" content="website">
    <meta property="og:site_name" content="<%= mp.brandLabel %>">
    <meta property="og:locale" content="<%= mp.ogLocale %>">
    <meta property="og:title" content="<%= mp.ogTitle %>">
    <meta property="og:description" content="<%= mp.ogDescription %>">
    <meta property="og:url" content="<%= canonicalUrl %>">
    <% if (propiedades.length > 0 && propiedades[0].fotoUrl) { %>
    <meta property="og:image" content="<%= propiedades[0].fotoUrl %>">
    <% } %>
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= mp.pageTitle %>">
    <meta name="twitter:description" content="<%= mp.twitterDescription %>">

    <!-- Schema.org JSON-LD -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "<%= mp.brandLabel %>",
      "url": "https://<%= platformDomain %>",
      "description": <%- JSON.stringify(mp.jsonLdSiteDescription) %>,
      "potentialAction": {
        "@type": "SearchAction",
        "target": {
          "@type": "EntryPoint",
          "urlTemplate": "https://<%= platformDomain %>/?q={search_term_string}"
        },
        "query-input": "required name=search_term_string"
      }
    }
    </script>
    <% if (propiedades.length > 0) { %>
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "ItemList",
      "name": <%- JSON.stringify(mp.jsonLdItemListName) %>,
      "description": <%- JSON.stringify(mp.jsonLdItemListDescription) %>,
      "numberOfItems": <%= propiedades.length %>,
      "itemListElement": [
        <%- propiedades.slice(0, 10).map((p, i) => {
          const tier = precioDesdeToSchemaPriceRange(p.precioDesde);
          return JSON.stringify({
            "@type": "ListItem",
            "position": i + 1,
            "item": {
              "@type": "LodgingBusiness",
              "name": p.titulo,
              "url": p.url,
              "image": p.fotoUrl || undefined,
              "maximumAttendeeCapacity": p.capacidad,
              ...(p.rating ? { "aggregateRating": {
                "@type": "AggregateRating",
                "ratingValue": p.rating,
                "reviewCount": p.numResenas,
                "bestRating": 5
              }} : {}),
              ...(tier ? { "priceRange": tier } : {})
            }
          });
        }).join(',\n        ') %>
      ]
    }
    </script>
    <% } %>

    <link rel="stylesheet" href="/public/css/website.css">
    <%- include('../partials/web-fonts') %>
    <%- include('../partials/ssr-fontawesome-deferred') %>
    <%- include('../partials/marketplace-common-styles') %>
</head>
<body class="bg-neutral-50 text-neutral-900 antialiased min-h-screen">
<%- include('../partials/marketplace-skip-main') %>

<!-- ═══ HEADER ═══ -->
<header class="mp-header">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex flex-wrap items-center gap-3 lg:gap-5">
        <a href="<%= mpHomeUrl %>" class="mp-logo flex-shrink-0 text-primary-600"><%= mp.brandLabel %></a>

        <a href="/google-hotels<%= mp.htmlLang === 'en' ? '?lang=en' : '' %>" class="hidden sm:inline-flex flex-shrink-0 text-sm font-semibold text-neutral-600 hover:text-primary-600 px-2 py-1 rounded-md whitespace-nowrap">
            <%= mp.navGoogleHotels %>
        </a>

        <!-- Search (GET) -->
        <form id="mp-search-form" method="GET" action="/" class="flex-1 max-w-3xl min-w-[200px] order-last sm:order-none w-full sm:w-auto">
            <div class="search-pill">
                <% if (mp.htmlLang === 'en') { %>
                <input type="hidden" name="lang" value="en">
                <% } %>
                <div class="search-segment">
                    <label for="s-destino"><%= mp.labelDestino %></label>
                    <input id="s-destino" name="q" type="text"
                           placeholder="<%= mp.placeholderDestino %>"
                           value="<%= busqueda %>">
                </div>
                <div class="search-segment" style="max-width: 140px;">
                    <label for="s-fecha-in"><%= mp.labelLlegada %></label>
                    <input id="s-fecha-in" name="fecha_in" type="date"
                           value="<%= fechaIn %>" style="color-scheme:light;">
                </div>
                <div class="search-segment" style="max-width: 140px;">
                    <label for="s-fecha-out"><%= mp.labelSalida %></label>
                    <input id="s-fecha-out" name="fecha_out" type="date"
                           value="<%= fechaOut %>" style="color-scheme:light;">
                </div>
                <div class="search-segment" style="max-width: 120px;">
                    <label for="s-personas"><%= mp.labelHuespedes %></label>
                    <input id="s-personas" name="personas" type="number"
                           placeholder="<%= mp.placeholderHuespedes %>" min="1" max="20"
                           value="<%= personas > 0 ? personas : '' %>">
                </div>
                <button type="submit" class="search-btn bg-primary-600 text-white hover:bg-primary-700" aria-label="<%= mp.ariaBuscar %>">
                    <i class="fas fa-search"></i>
                </button>
            </div>
        </form>

        <nav class="flex-shrink-0 flex items-center gap-1 text-sm font-semibold sm:ml-auto" aria-label="<%= mp.langSwitchTitle %>">
            <a href="<%= mpLinkEs %>" class="px-2 py-1 rounded-md <%= mp.htmlLang === 'es' ? 'bg-neutral-100 text-neutral-900' : 'text-primary-600 hover:underline' %>"><%= mp.langSwitchEs %></a>
            <span class="text-neutral-300">|</span>
            <a href="<%= mpLinkEn %>" class="px-2 py-1 rounded-md <%= mp.htmlLang === 'en' ? 'bg-neutral-100 text-neutral-900' : 'text-primary-600 hover:underline' %>"><%= mp.langSwitchEn %></a>
        </nav>

        <a href="/google-hotels<%= mp.htmlLang === 'en' ? '?lang=en' : '' %>" class="sm:hidden w-full text-center text-sm font-semibold text-primary-600 py-1">
            <%= mp.navGoogleHotels %>
        </a>
    </div>

    <!-- Ordenación (misma query que el buscador) -->
    <div class="border-t border-neutral-100 bg-white/80">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-2 flex flex-wrap items-center justify-end gap-2">
            <label for="mp-sort" class="text-sm font-medium text-neutral-600"><%= mp.labelSort %></label>
            <select id="mp-sort" name="sort" form="mp-search-form"
                    class="text-sm border border-neutral-200 rounded-lg px-3 py-1.5 bg-white text-neutral-900 focus:ring-2 focus:ring-primary-500 focus:border-primary-500 max-w-full"
                    onchange="var f=document.getElementById('mp-search-form'); if(f) f.submit();">
                <option value="" <%= !sort ? 'selected' : '' %>><%= mp.sortRecommended %></option>
                <option value="rating" <%= sort === 'rating' ? 'selected' : '' %>><%= mp.sortRating %></option>
                <option value="valor" <%= sort === 'valor' ? 'selected' : '' %>><%= mp.sortPriceLow %></option>
                <option value="valor_desc" <%= sort === 'valor_desc' ? 'selected' : '' %>><%= mp.sortPriceHigh %></option>
            </select>
        </div>
    </div>
</header>

<% if (!hayBusqueda) { %>
<section class="mp-hero" aria-labelledby="mp-hero-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-8 pb-10 md:pt-12 md:pb-14 text-center">
        <h1 id="mp-hero-heading" class="text-3xl sm:text-4xl md:text-5xl font-semibold tracking-tight text-neutral-900 max-w-3xl mx-auto leading-tight">
            <%= mp.heroTitle %>
        </h1>
        <p class="mt-4 text-base sm:text-lg text-neutral-600 max-w-2xl mx-auto leading-relaxed">
            <%= mp.heroSubtitle %>
        </p>
    </div>
</section>
<% } %>

<!-- ═══ MAIN ═══ -->
<main id="main-content" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-10">

    <%
    const _priceLocale = mp.htmlLang === 'en' ? 'en-US' : 'es-CL';
    const formatPrecio = (n) => {
        if (!n) return null;
        return '$' + Number(n).toLocaleString(_priceLocale);
    };
    %>

    <!-- Destacados (solo si no hay búsqueda activa) -->
    <% if (!hayBusqueda && destacados.length > 0) { %>
    <section class="mb-14" aria-labelledby="mp-destacados-heading">
        <h2 id="mp-destacados-heading" class="section-title">
            <i class="fas fa-star text-warning-500 mr-2" style="font-size:1.1rem;"></i>
            <%= mp.sectionFavoritos %>
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            <% destacados.forEach(p => { %>
            <a href="/ir?s=<%= p.subdominio %>&id=<%= p.id %>" class="prop-card">
                <div class="prop-photo">
                    <% if (p.fotoUrl) { %>
                        <img src="<%= p.fotoUrl %>" alt="<%= p.titulo %>" loading="lazy">
                    <% } else { %>
                        <div class="prop-photo-placeholder"><i class="fas fa-home"></i></div>
                    <% } %>
                    <% if (p.tienePromoTarifa && p.promoTarifaPctMax > 0) { %>
                    <span class="mp-badge-promo"><i class="fas fa-tag mr-1"></i>-<%= p.promoTarifaPctMax %>%</span>
                    <% } %>
                    <span class="badge-fav"><i class="fas fa-medal mr-1 text-warning-500"></i><%= mp.badgeFavorito %></span>
                </div>
                <div class="prop-body">
                    <p class="prop-title"><%= p.titulo %></p>
                    <p class="prop-sub"><%= p.empresaNombre %> · <%= p.capacidad %> <%= p.capacidad !== 1 ? mp.people : mp.person %></p>
                    <% if (p.rating) { %>
                    <div class="prop-rating">
                        <i class="fas fa-star text-warning-500" style="font-size:11px;"></i>
                        <%= p.rating %>
                        <% if (p.numResenas > 0) { %><span>(<%= p.numResenas %> <%= mp.reviews %>)</span><% } %>
                    </div>
                    <% } %>
                    <% if (p.precioDesde) { %>
                    <p class="prop-price"><strong><%= formatPrecio(p.precioDesde) %></strong> <em><%= mp.pricePerNight %></em></p>
                    <% } %>
                </div>
            </a>
            <% }); %>
        </div>
    </section>
    <% } %>

    <!-- Resultados / Todos los alojamientos -->
    <section aria-labelledby="mp-lista-heading">
        <% if (hayBusqueda) { %>
        <h1 id="mp-lista-heading" class="section-title">
                <% if (busqueda) { %>
                    <%= mp.sectionResultadosConQuery %> "<strong><%= busqueda %></strong>"
                <% } else { %>
                    <%= mp.sectionAlojamientosPara %> <%= personas %> <%= personas !== 1 ? mp.people : mp.person %>
                <% } %>
                <span class="text-base font-normal text-neutral-400 ml-2">· <%= totalResultados %> <%= mp.lodgings %></span>
                <a href="<%= mpHomeUrl %>" class="text-sm font-normal text-primary-600 hover:underline ml-4">
                    <i class="fas fa-times-circle mr-1"></i><%= mp.clearFilters %>
                </a>
        </h1>
        <% } else { %>
        <h2 id="mp-lista-heading" class="section-title">
                <%= mp.sectionTodos %>
                <span class="text-base font-normal text-neutral-400 ml-2">· <%= totalResultados %></span>
        </h2>
        <% } %>

        <% if (propiedades.length === 0) { %>
        <div class="text-center py-20">
            <i class="fas fa-search text-4xl text-neutral-200 mb-4"></i>
            <p class="text-neutral-500 text-lg"><%= mp.noResults %></p>
            <a href="<%= mpHomeUrl %>" class="inline-block mt-4 text-primary-600 hover:underline font-medium"><%= mp.verTodos %></a>
        </div>
        <% } else { %>
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
            <% propiedades.forEach(p => { %>
            <a href="/ir?s=<%= p.subdominio %>&id=<%= p.id %>" class="prop-card">
                <div class="prop-photo">
                    <% if (p.fotoUrl) { %>
                        <img src="<%= p.fotoUrl %>" alt="<%= p.titulo %>" loading="lazy">
                    <% } else { %>
                        <div class="prop-photo-placeholder"><i class="fas fa-home"></i></div>
                    <% } %>
                    <% if (p.tienePromoTarifa && p.promoTarifaPctMax > 0) { %>
                    <span class="mp-badge-promo"><i class="fas fa-tag mr-1"></i>-<%= p.promoTarifaPctMax %>%</span>
                    <% } %>
                </div>
                <div class="prop-body">
                    <p class="prop-title"><%= p.titulo %></p>
                    <p class="prop-sub"><%= p.empresaNombre %> · <%= p.capacidad %> <%= p.capacidad !== 1 ? mp.people : mp.person %></p>
                    <% if (p.rating) { %>
                    <div class="prop-rating">
                        <i class="fas fa-star text-warning-500" style="font-size:11px;"></i>
                        <%= p.rating %>
                        <% if (p.numResenas > 0) { %><span>(<%= p.numResenas %> <%= mp.reviews %>)</span><% } %>
                    </div>
                    <% } %>
                    <% if (p.precioDesde) { %>
                    <p class="prop-price"><strong><%= formatPrecio(p.precioDesde) %></strong> <em><%= mp.pricePerNight %></em></p>
                    <% } %>
                </div>
            </a>
            <% }); %>
        </div>
        <% } %>
    </section>
</main>

<%- include('../partials/marketplace-footer', { mp, mpHomeUrl, footerMode: 'home' }) %>

</body>
</html>
