<%#
  Locals: mp, mpHomeUrl, footerMode: 'home' | 'google-hotels'
%>
<footer class="mp-footer">
    <div class="mp-footer__inner mp-container py-10 md:py-12">
        <div class="mp-footer__grid flex flex-col gap-10 lg:flex-row lg:items-start lg:justify-between lg:gap-16">
            <div class="flex flex-col items-center lg:items-start gap-4 lg:max-w-md">
                <div class="mp-footer-logo mp-footer-logo-card flex justify-center lg:justify-start w-full">
                    <%- include('marketplace-brand-logo', { mp, mpHomeUrl, logoVariant: 'footer' }) %>
                </div>
                <p class="mp-footer__tagline text-center lg:text-left leading-relaxed">
                    <%= mp.footerTagline %>
                </p>
            </div>
            <nav class="mp-footer-nav flex flex-wrap items-center justify-center lg:justify-end gap-x-8 gap-y-3 text-sm font-semibold" aria-label="<%= mp.htmlLang === 'en' ? 'Legal and links' : 'Legal y enlaces' %>">
                <% if (footerMode === 'google-hotels') { %>
                <a href="<%= mpHomeUrl %>" class="mp-footer__link"><%= mp.ghCatalogBackHome %></a>
                <% } %>
                <a href="/legal/terms" class="mp-footer__link"><%= mp.footerTerms %></a>
                <a href="/legal/privacy" class="mp-footer__link"><%= mp.footerPrivacy %></a>
            </nav>
        </div>
    </div>
</footer>
