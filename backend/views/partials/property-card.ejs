<%# backend/views/partials/property-card.ejs %>
<%
    const _pcEn = (typeof htmlLocale !== 'undefined' && htmlLocale === 'en');
    const _card       = prop.websiteData?.cardImage || {};
    const _fullImg    = String(_card.storagePath || '').trim();
    let _thumbImg     = String(_card.thumbnailUrl || '').trim();
    if (_fullImg && (!_thumbImg || _thumbImg === _fullImg) && /\.webp(\?|$)/i.test(_fullImg) && !_fullImg.includes('_thumb.webp')) {
        _thumbImg = _fullImg.replace(/\.webp(\?|$)/i, '_thumb.webp$1');
    }
    // Thumbnail móvil (_sm.webp, 400px) — URL derivada desde full, no desde thumb.
    let _smImg = '';
    if (_fullImg && /\.webp(\?|$)/i.test(_fullImg) && !_fullImg.includes('_thumb.webp') && !_fullImg.includes('_sm.webp')) {
        _smImg = _fullImg.replace(/\.webp(\?|$)/i, '_sm.webp$1');
    }
    // Listado home: srcset con 400w (móvil) y 560w (resto).
    const _img        = (_thumbImg || _fullImg || '').trim()
        || 'https://placehold.co/400x400/e5e7eb/9ca3af?text=Sin+imagen';
    const _alt      = prop.websiteData?.cardImage?.altText || prop.nombre;
    const _tiene    = isSearchResult && prop.pricing && prop.pricing.totalPriceCLP > 0;
    const _pxnExact = _tiene && prop.pricing.nights > 0 ? Math.round(prop.pricing.totalPriceCLP / prop.pricing.nights) : 0;
    const _pxnBase  = prop.precioBaseNoche > 0 ? prop.precioBaseNoche : 0;
    const _pxn      = _pxnExact > 0 ? _pxnExact : _pxnBase;
    const _esBase   = !_tiene && _pxnBase > 0;
    const _fmtCLP   = (v) => `$${Math.round(v || 0).toLocaleString(_pcEn ? 'en-US' : 'es-CL')}`;
    const _link     = `/propiedad/${prop.id}?fechaLlegada=${query.fechaLlegada||''}&fechaSalida=${query.fechaSalida||''}&personas=${query.personas||''}`;
    const _dorm     = prop.numPiezas ? (_pcEn ? `${prop.numPiezas} bed` + (prop.numPiezas > 1 ? 's' : '') : `${prop.numPiezas} dorm.`) : '';
    const _banos    = prop.numBanos  ? (_pcEn ? `${prop.numBanos} bath` + (prop.numBanos > 1 ? 's' : '') : `${prop.numBanos} baños`) : '';
    const _detalles = [_dorm, _banos, `${prop.capacidad} ${_pcEn ? (prop.capacidad === 1 ? 'guest' : 'guests') : 'pers.'}`].filter(Boolean).join(' · ');
%>
<a href="<%= _link %>" class="group block focus:outline-none">
    <div class="relative overflow-hidden rounded-xl bg-gray-100" style="aspect-ratio:1/1">
        <img src="<%= _img %>" alt="<%= _alt %>" width="560" height="560" loading="lazy" decoding="async"
             <% if (_smImg) { %>srcset="<%= _smImg %> 400w, <%= _img %> 560w" sizes="(max-width: 639px) 150px, 560px"<% } %>
             onerror="this.onerror=null;this.src='https://placehold.co/560x560/e5e7eb/9ca3af?text=Foto';"
             class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105">
        <% if (_tiene) { %>
        <span class="absolute top-3 left-3 bg-white/95 text-success-700 text-xs font-bold px-2.5 py-1 rounded-full shadow-sm backdrop-blur-sm">
            <%= _pcEn ? '✓ Available' : '✓ Disponible' %>
        </span>
        <% } %>
    </div>
    <div class="mt-3 px-0.5">
        <h3 class="m-0 font-semibold text-gray-900 text-sm leading-snug line-clamp-1"><%= prop.nombre %></h3>
        <p class="text-xs text-gray-600 mt-0.5"><%= _detalles %></p>
        <p class="mt-1.5 text-sm font-bold text-gray-900">
            <% if (_tiene && _pxnExact > 0) { %>
                <%= _fmtCLP(_pxnExact) %> <span class="font-normal text-gray-600">/ <%= _pcEn ? 'night' : 'noche' %></span>
            <% } else if (_esBase) { %>
                <span class="font-normal text-gray-600 text-xs"><%= _pcEn ? 'from' : 'desde' %></span> <%= _fmtCLP(_pxnBase) %> <span class="font-normal text-gray-600">/ <%= _pcEn ? 'night' : 'noche' %></span>
            <% } else { %>
                <span class="font-normal text-gray-600 text-xs"><%= _pcEn ? 'Check availability' : 'Consultar disponibilidad' %></span>
            <% } %>
        </p>
    </div>
</a>
