<%# Estilos compartidos: home marketplace + /google-hotels (TASKS/tema/SM-auditoria-calidad/solo-ui.md) %>
<style>
    body { font-family: 'Inter', sans-serif; }
    .mp-header { background: rgba(255,255,255,0.92); border-bottom: 1px solid rgb(229 231 235); position: sticky; top: 0; z-index: 50; backdrop-filter: blur(10px); }
    .mp-brand-logo { line-height: 0; text-decoration: none; color: inherit; }
    .mp-brand-logo__img {
        height: 36px;
        width: auto;
        max-width: min(200px, 46vw);
        object-fit: contain;
        display: block;
    }
    .mp-brand-logo--footer .mp-brand-logo__img {
        height: 28px;
        max-width: 180px;
        margin-left: auto;
        margin-right: auto;
    }
    .mp-hero {
        background: linear-gradient(180deg, rgb(250 250 250) 0%, rgb(255 255 255) 55%, rgb(255 255 255) 100%);
        border-bottom: 1px solid rgb(229 231 235);
    }
    .search-pill {
        display: flex; align-items: center;
        background: #fff; border: 1px solid rgb(229 231 235);
        border-radius: 9999px; overflow: hidden;
        box-shadow: 0 1px 2px rgba(0,0,0,0.04), 0 8px 24px rgba(0,0,0,0.06);
        max-width: 720px; width: 100%; margin: 0 auto;
    }
    .search-segment {
        flex: 1; padding: 12px 20px; cursor: pointer; border: none;
        background: transparent; text-align: left; min-width: 0;
    }
    .search-segment + .search-segment { border-left: 1.5px solid rgb(229 231 235); }
    .search-segment label { display: block; font-size: 11px; font-weight: 700; color: rgb(17 24 39); margin-bottom: 2px; cursor: pointer; }
    .search-segment input { width: 100%; border: none; outline: none; font-size: 13px; color: rgb(75 85 99); background: transparent; font-family: inherit; }
    .search-segment input::placeholder { color: rgb(156 163 175); }
    .search-btn {
        margin: 6px; border: none;
        border-radius: 9999px; width: 48px; height: 48px; cursor: pointer;
        display: flex; align-items: center; justify-content: center;
        font-size: 16px; flex-shrink: 0;
    }
    .search-mobile-collapsed {
        display: none;
    }
    .search-mobile-collapsed--hidden {
        display: none !important;
    }
    .search-mobile-panel-header {
        display: none;
    }
    .search-mobile-panel-title {
        font-size: 15px;
        font-weight: 700;
        color: rgb(17 24 39);
    }
    .search-mobile-panel-close {
        border: none;
        background: transparent;
        padding: 8px 10px;
        border-radius: 9999px;
        color: rgb(75 85 99);
        cursor: pointer;
        font-size: 16px;
        line-height: 1;
        transition: color 0.15s ease, background 0.15s ease;
    }
    .search-mobile-panel-close:hover {
        color: rgb(79 70 229);
        background: rgb(238 242 255);
    }
    @media (max-width: 767px) {
        .mp-header .max-w-7xl {
            padding-top: 10px;
            padding-bottom: 10px;
        }
        .search-mobile-collapsed {
            display: flex;
            align-items: center;
            gap: 12px;
            width: 100%;
            max-width: 720px;
            margin: 0 auto 6px;
            padding: 12px 16px;
            border: 1px solid rgb(229 231 235);
            border-radius: 9999px;
            background: #fff;
            box-shadow: 0 1px 2px rgba(0,0,0,0.05), 0 4px 16px rgba(0,0,0,0.06);
            cursor: pointer;
            text-align: left;
            font-family: inherit;
            transition: box-shadow 0.2s ease, transform 0.15s ease;
        }
        .search-mobile-collapsed:active {
            transform: scale(0.99);
        }
        .search-mobile-collapsed__icon {
            flex-shrink: 0;
            color: rgb(79 70 229);
            font-size: 15px;
        }
        .search-mobile-collapsed__text {
            flex: 1;
            min-width: 0;
        }
        .search-mobile-collapsed__title {
            display: block;
            font-size: 14px;
            font-weight: 700;
            color: rgb(17 24 39);
        }
        .search-mobile-collapsed__sub {
            display: block;
            font-size: 12px;
            color: rgb(107 114 128);
            margin-top: 2px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }
        .search-mobile-collapsed__chev {
            flex-shrink: 0;
            color: rgb(156 163 175);
            font-size: 12px;
        }
        .search-mobile-panel:not(.is-open) {
            max-height: 0;
            overflow: hidden;
            opacity: 0;
            pointer-events: none;
            margin: 0;
            padding: 0;
        }
        .search-mobile-panel.is-open {
            max-height: 1200px;
            opacity: 1;
            pointer-events: auto;
            overflow: visible;
            transition: max-height 0.28s ease, opacity 0.2s ease;
        }
        .search-mobile-panel.is-open .search-mobile-panel-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 4px 8px 4px;
        }
        .search-pill {
            display: flex;
            flex-wrap: wrap;
            align-items: stretch;
            border-radius: 14px;
            max-width: 100%;
            box-shadow: 0 1px 2px rgba(0,0,0,0.04), 0 4px 14px rgba(0,0,0,0.06);
        }
        .search-segment {
            padding: 8px 10px;
            min-height: 58px;
            width: 50%;
            flex: 0 0 50%;
            max-width: none !important;
        }
        .search-segment + .search-segment {
            border-left: none;
            border-top: 1px solid rgb(229 231 235);
        }
        .search-segment-llegada,
        .search-segment-huespedes {
            border-left: 1px solid rgb(229 231 235);
        }
        .search-segment-llegada {
            border-top: none;
        }
        .search-segment-huespedes {
            width: calc(100% - 54px);
            flex: 0 0 calc(100% - 54px);
            border-right: 1px solid rgb(229 231 235);
        }
        .search-segment label {
            font-size: 10px;
            margin-bottom: 1px;
            color: rgb(107 114 128);
        }
        .search-segment input {
            font-size: 12px;
        }
        .search-btn {
            width: 42px;
            height: 42px;
            min-width: 42px;
            align-self: flex-end;
            margin: 8px 6px 8px;
            font-size: 14px;
        }
    }
    @media (min-width: 768px) {
        .search-mobile-collapsed {
            display: none !important;
        }
        .search-mobile-panel-header {
            display: none !important;
        }
        .search-mobile-panel {
            max-height: none !important;
            opacity: 1 !important;
            overflow: visible !important;
            pointer-events: auto !important;
        }
    }
    .prop-card {
        background: #fff; border-radius: 12px; overflow: hidden;
        transition: transform 0.18s ease, box-shadow 0.18s ease;
        text-decoration: none; color: inherit; display: block;
        border: 1px solid rgb(243 244 246);
        box-shadow: 0 1px 2px rgba(0,0,0,0.04);
    }
    .prop-card:hover { transform: translateY(-2px); box-shadow: 0 12px 28px rgba(0,0,0,0.1); }
    .prop-photo { position: relative; aspect-ratio: 1 / 1; background: rgb(243 244 246); overflow: hidden; border-radius: 12px 12px 0 0; }
    .prop-photo img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.3s; }
    .prop-card:hover .prop-photo img { transform: scale(1.04); }
    .prop-photo-placeholder { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; background: linear-gradient(135deg, rgb(224 231 255), rgb(240 244 255)); color: rgb(165 180 252); font-size: 3rem; }
    .badge-fav { position: absolute; top: 10px; left: 10px; background: #fff; border-radius: 8px; padding: 4px 10px; font-size: 11px; font-weight: 700; color: rgb(17 24 39); box-shadow: 0 1px 4px rgba(0,0,0,0.15); }
    .mp-badge-promo { position: absolute; top: 10px; right: 10px; background: rgb(255 247 237); color: rgb(154 52 18); border: 1px solid rgb(253 186 116); border-radius: 8px; padding: 4px 10px; font-size: 11px; font-weight: 700; box-shadow: 0 1px 4px rgba(0,0,0,0.12); }
    .prop-body { padding: 14px 16px 16px; }
    .prop-title { font-size: 14px; font-weight: 700; color: rgb(17 24 39); line-height: 1.35; margin-bottom: 3px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    .prop-sub { font-size: 12px; color: rgb(75 85 99); margin-bottom: 8px; }
    .prop-rating { display: flex; align-items: center; gap: 4px; font-size: 12px; font-weight: 600; color: rgb(17 24 39); }
    .prop-rating span { color: rgb(75 85 99); font-weight: 400; }
    .prop-price { font-size: 14px; color: rgb(17 24 39); margin-top: 8px; }
    .prop-price strong { font-weight: 700; }
    .prop-price em { font-style: normal; color: rgb(75 85 99); font-size: 12px; }
    .section-title { font-size: 1.35rem; font-weight: 700; color: rgb(17 24 39); margin-bottom: 20px; }
    .mp-alert-soft { background: #fff; border: 1px solid rgb(229 231 235); border-radius: 12px; padding: 1rem 1.25rem; color: rgb(55 65 81); font-size: 0.95rem; }
    .mp-gh-cta-row { display: flex; align-items: center; justify-content: space-between; gap: 0.5rem; flex-wrap: wrap; margin-top: 0.25rem; }
    .mp-gh-cta-text { font-size: 0.875rem; font-weight: 600; color: rgb(37 99 235); display: inline-flex; align-items: center; gap: 0.35rem; }
</style>
