<%#
  Locals: mp, mpHomeUrl, logoVariant opcional: 'header' | 'footer'
  Solo marca transparente (WebP + PNG). Tamaño visual controlado por CSS (.mp-brand-logo__img).
%>
<% const variant = logoVariant === 'footer' ? 'footer' : 'header'; %>
<a href="<%= mpHomeUrl %>"
   class="mp-brand-logo mp-brand-logo--<%= variant %> inline-flex items-center flex-shrink-0 rounded-md focus:outline-none focus-visible:ring-2 focus-visible:ring-neutral-400 focus-visible:ring-offset-2 <%= variant === 'footer' ? 'justify-center' : '' %>">
    <picture>
        <source type="image/webp" srcset="/public/branding/logo-transparent.webp">
        <img src="/public/branding/logo-transparent.png"
             alt="<%= mp.brandLabel %>"
             class="mp-brand-logo__img"
             width="360"
             height="196"
             decoding="async"
             <% if (variant === 'header') { %>fetchpriority="high"<% } %> />
    </picture>
</a>
