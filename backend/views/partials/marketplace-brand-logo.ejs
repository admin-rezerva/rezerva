<%#
  Locals: mp, mpHomeUrl, logoVariant opcional: 'header' | 'footer'
  Dimensiones intrínsecas alineadas a build-manifest.json (360×196)
%>
<% const variant = logoVariant === 'footer' ? 'footer' : 'header'; %>
<a href="<%= mpHomeUrl %>"
   class="mp-brand-logo mp-brand-logo--<%= variant %> inline-flex items-center flex-shrink-0 rounded-md focus:outline-none focus-visible:ring-2 focus-visible:ring-primary-500 focus-visible:ring-offset-2 <%= variant === 'footer' ? 'justify-center' : '' %>">
    <% if (variant === 'header') { %>
    <picture>
        <source type="image/webp" media="(prefers-color-scheme: dark)" srcset="/public/branding/logo-bg-white.webp">
        <source type="image/webp" srcset="/public/branding/logo-transparent.webp">
        <source type="image/png" media="(prefers-color-scheme: dark)" srcset="/public/branding/logo-bg-white.png">
        <img src="/public/branding/logo-transparent.png"
             alt="<%= mp.brandLabel %>"
             class="mp-brand-logo__img"
             width="360"
             height="196"
             decoding="async"
             fetchpriority="high" />
    </picture>
    <% } else { %>
    <picture>
        <source type="image/webp" srcset="/public/branding/logo-transparent.webp">
        <img src="/public/branding/logo-transparent.png"
             alt="<%= mp.brandLabel %>"
             class="mp-brand-logo__img"
             width="360"
             height="196"
             decoding="async" />
    </picture>
    <% } %>
</a>
