<%- /* backend/views/partials/header.ejs */ %>
<%
    const _navHl = (typeof htmlLang !== 'undefined' && htmlLang === 'en') ? 'en' : 'es';
    const _navTermsPublished = empresa.websiteSettings?.terminosCondiciones?.publicado === true;
    const _navTermsUrl = locals.platformTerminosUrl || '/terminos-y-condiciones';
%>
<a href="#main-content" class="absolute left-[-10000px] top-auto z-[100] px-4 py-2 bg-primary-600 text-white rounded-md focus:left-4 focus:top-4 focus:outline-none focus:ring-2 focus:ring-primary-400"><%= _navHl === 'en' ? 'Skip to main content' : 'Saltar al contenido principal' %></a>
<header class="bg-white shadow-sm sticky top-0 z-50">
    <div class="container py-3 flex items-center justify-between">
        <a href="/" class="flex items-center space-x-3">
            <%# Logo: brandIdentity nunca tuvo logoUrl; usar logos.* o theme (URLs relativas al bucket → https) %>
            <%
                const _normLogo = typeof normalizeWebsiteImageUrl === 'function' ? normalizeWebsiteImageUrl : (u) => String(u || '').trim();
                const _coerceLogo = (raw) => {
                    if (!raw) return '';
                    if (typeof raw === 'string') return raw.trim();
                    if (typeof raw === 'object' && raw.url) return String(raw.url).trim();
                    return '';
                };
                const _headerLogoRaw =
                    _coerceLogo(locals.brandIdentity?.logos?.primary)
                    || _coerceLogo(locals.brandIdentity?.logos?.secondary)
                    || _coerceLogo(empresa.websiteSettings?.brand?.logos?.primary)
                    || _coerceLogo(empresa.websiteSettings?.brand?.logos?.secondary)
                    || String(empresa.websiteSettings?.theme?.logoUrl || '').trim();
                const _headerLogoUrl = _normLogo(_headerLogoRaw);
            %>
            <% if (_headerLogoUrl) { %>
                <img src="<%= _headerLogoUrl %>" alt="<%= empresa.nombre %> Logo" width="150" height="36" class="h-9 max-w-[150px] object-contain" decoding="async" onerror="this.style.display='none'">
            <% } %>
            <span class="text-xl md:text-2xl font-bold text-gray-900 truncate">
                <%= empresa.nombre %>
            </span>
        </a>
        <nav class="hidden sm:flex items-center space-x-4">
            <a href="/#propiedades" class="text-gray-600 hover:text-primary-600 font-semibold transition text-sm"><%= _navHl === 'en' ? 'Browse stays' : 'Ver Propiedades' %></a>
            <% if (_navTermsPublished) { %>
            <a href="<%= _navTermsUrl %>" class="text-gray-600 hover:text-primary-600 font-semibold transition text-sm"><%= _navHl === 'en' ? 'Terms' : 'Términos' %></a>
            <% } %>
            
            <%# --- INICIO BOTÓN WHATSAPP HEADER --- %>
            <%# Ocultar si estamos en la página de una propiedad (paginaPropiedad se define en propiedad.ejs) %>
            <% if (empresa.contactoTelefono && empresa.contactoNombre && !locals.paginaPropiedad) { %>
                <% 
                    const telefonoLimpio = empresa.contactoTelefono.replace(/\D/g, '');
                    const nombreAnfitrion = empresa.contactoNombre.split(' ')[0];
                    const mensajeGenerico = _navHl === 'en'
                        ? `Hi ${nombreAnfitrion}, I need help with a booking.`
                        : `Hola ${nombreAnfitrion}, necesito ayuda con una reserva.`;
                    const whatsappUrl = `https://wa.me/${telefonoLimpio}?text=${encodeURIComponent(mensajeGenerico)}`;
                %>
                <a href="<%= whatsappUrl %>" target="_blank" rel="noopener noreferrer" class="bg-success-800 hover:bg-success-900 text-white px-4 py-2 rounded-lg font-semibold transition flex items-center" aria-label="<%= _navHl === 'en' ? 'Contact on WhatsApp — header' : 'Contactar por WhatsApp — barra superior' %>">
                    <i class="fab fa-whatsapp w-5 h-5 mr-2 text-white" aria-hidden="true"></i>
                    <%= _navHl === 'en' ? `Hi, I'm ${nombreAnfitrion} — can I help?` : `Hola, soy ${nombreAnfitrion}, ¿te ayudo?` %>
                </a>
            <% } %>
            <%# --- FIN BOTÓN WHATSAPP HEADER --- %>
        </nav>
        
        <%# --- Botón Móvil --- %>
        <div class="sm:hidden">
             <% if (empresa.contactoTelefono && !locals.paginaPropiedad) { %>
                <% 
                    const telefonoLimpio = empresa.contactoTelefono.replace(/\D/g, '');
                    const nombreAnfitrion = (empresa.contactoNombre || 'Anfitrión').split(' ')[0];
                    const mensajeGenerico = _navHl === 'en'
                        ? `Hi ${nombreAnfitrion}, I need help with a booking.`
                        : `Hola ${nombreAnfitrion}, necesito ayuda con una reserva.`;
                    const whatsappUrl = `https://wa.me/${telefonoLimpio}?text=${encodeURIComponent(mensajeGenerico)}`;
                %>
                <a href="<%= whatsappUrl %>" target="_blank" rel="noopener noreferrer"
                   aria-label="<%= _navHl === 'en' ? 'Contact on WhatsApp' : 'Contactar por WhatsApp' %>"
                   class="bg-success-800 hover:bg-success-900 text-white p-2 rounded-lg">
                    <i class="fab fa-whatsapp w-5 h-5 text-white m-0" aria-hidden="true"></i>
                </a>
             <% } %>
        </div>
    </div>
</header>